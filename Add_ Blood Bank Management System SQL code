-------------------------------------------------------------
-- TABLES
-------------------------------------------------------------
CREATE TABLE Donor (
    DonorID INT IDENTITY PRIMARY KEY,
    FirstName VARCHAR(50),
    LastName VARCHAR(50),
    Gender CHAR(1),
    DateOfBirth DATE,
    BloodGroup VARCHAR(5),
    DiseaseStatus VARCHAR(50),
    ContactNumber VARCHAR(20),
    Email VARCHAR(100),
    Address VARCHAR(255),
    RegistrationDate DATE DEFAULT GETDATE()
);

CREATE TABLE Hospital (
    HospitalID INT IDENTITY PRIMARY KEY,
    HospitalName VARCHAR(100),
    ContactNumber VARCHAR(20),
    Address VARCHAR(255)
);

CREATE TABLE Recipient (
    RecipientID INT IDENTITY PRIMARY KEY,
    FirstName VARCHAR(50),
    LastName VARCHAR(50),
    Gender CHAR(1),
    DateOfBirth DATE,
    BloodGroup VARCHAR(5),
    ContactNumber VARCHAR(20),
    Email VARCHAR(100),
    Address VARCHAR(255),
    HospitalID INT FOREIGN KEY REFERENCES Hospital(HospitalID)
);

CREATE TABLE BloodInventory (
    BloodID INT IDENTITY PRIMARY KEY,
    DonorID INT FOREIGN KEY REFERENCES Donor(DonorID),
    CollectionDate DATE,
    ExpiryDate DATE,
    ContaminationStatus VARCHAR(10),
    AvailabilityStatus VARCHAR(15)
);

CREATE TABLE HospitalRequest (
    RequestID INT IDENTITY PRIMARY KEY,
    HospitalID INT FOREIGN KEY REFERENCES Hospital(HospitalID),
    RecipientID INT FOREIGN KEY REFERENCES Recipient(RecipientID),
    BloodID INT FOREIGN KEY REFERENCES BloodInventory(BloodID),
    RequestDate DATE DEFAULT GETDATE(),
    Status VARCHAR(20)
);

CREATE TABLE QualityControl (
    QCID INT IDENTITY PRIMARY KEY,
    BloodID INT FOREIGN KEY REFERENCES BloodInventory(BloodID),
    TestDate DATE,
    TestResult VARCHAR(20),
    Remarks VARCHAR(255)
);
GO

