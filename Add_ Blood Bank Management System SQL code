-------------------------------------------------------------
-- VIEWS
-------------------------------------------------------------
IF OBJECT_ID('vw_AvailableBlood','V') IS NOT NULL DROP VIEW vw_AvailableBlood;
GO
CREATE VIEW vw_AvailableBlood AS
SELECT b.BloodID, d.BloodGroup, b.AvailabilityStatus
FROM BloodInventory b
JOIN Donor d ON b.DonorID = d.DonorID
WHERE b.AvailabilityStatus='Available';
GO

IF OBJECT_ID('vw_HealthyDonors','V') IS NOT NULL DROP VIEW vw_HealthyDonors;
GO
CREATE VIEW vw_HealthyDonors AS
SELECT * FROM Donor WHERE DiseaseStatus='None';
GO

-------------------------------------------------------------
-- STORED PROCEDURES
-------------------------------------------------------------
IF OBJECT_ID('GetBloodByGroup','P') IS NOT NULL
    DROP PROCEDURE GetBloodByGroup;
GO
CREATE PROCEDURE GetBloodByGroup
    @BloodGroup VARCHAR(5)
AS
BEGIN
    SELECT FirstName, LastName, BloodGroup
    FROM Donor
    WHERE BloodGroup = @BloodGroup;
END;
GO

IF OBJECT_ID('PendingRequests','P') IS NOT NULL
    DROP PROCEDURE PendingRequests;
GO
CREATE PROCEDURE PendingRequests
AS
BEGIN
    SELECT * FROM HospitalRequest WHERE Status='Pending';
END;
GO

-------------------------------------------------------------
-- TRIGGER
-------------------------------------------------------------
IF OBJECT_ID('trg_UpdateAvailability','TR') IS NOT NULL
    DROP TRIGGER trg_UpdateAvailability;
GO
CREATE TRIGGER trg_UpdateAvailability
ON HospitalRequest
AFTER INSERT
AS
BEGIN
    UPDATE BloodInventory
    SET AvailabilityStatus='Used'
    WHERE BloodID IN (SELECT BloodID FROM inserted);
END;
GO

-------------------------------------------------------------
-- COMPLEX JOIN REPORT
-------------------------------------------------------------
SELECT 
    d.FirstName + ' ' + d.LastName AS DonorName,
    d.BloodGroup,
    h.HospitalName,
    r.FirstName + ' ' + r.LastName AS RecipientName,
    hr.Status
FROM HospitalRequest hr
JOIN Hospital h ON hr.HospitalID = h.HospitalID
JOIN Recipient r ON hr.RecipientID = r.RecipientID
JOIN BloodInventory b ON hr.BloodID = b.BloodID
JOIN Donor d ON b.DonorID = d.DonorID;
GO

